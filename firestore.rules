rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'points', 'createdAt']) && 
             data.displayName is string &&
             data.email is string &&
             data.points is number &&
             data.isAdmin is bool;
    }

    // --- Collections ---

    // Admin lookup collection (Read only by system/admins)
    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
      // Users can read and write their own data
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().isAdmin == false;
      allow update: if (isOwner(userId) && (
        // Users can update their profile but NOT their admin status
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'avatarUrl', 'points', 'streak', 'totalScans', 'co2SavedKg', 'currentLeague', 'updatedAt', 'lastActive'])
      )) || isAdmin();
      
      // Leaderboard: Everyone can list users to See names and points
      allow list: if isSignedIn();
    }

    match /users/{userId}/scans/{scanId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin(); // Only admins can delete history for cleanup
    }
  }
}
