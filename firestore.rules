rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'points', 'createdAt']) && 
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string &&
             data.points is number && data.points >= 0 &&
             data.createdAt is timestamp;
    }

    // Scan validation
    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'itemName', 'category', 'pointsAwarded', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.itemName is string &&
             data.category is string &&
             data.pointsAwarded is number &&
             data.timestamp == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'avatarUrl', 'points', 'streak', 'totalScans', 'co2SavedKg', 'currentLeague', 'updatedAt', 'lastActive'])
      );
      // Public leaderboard: only allow listing users if we filter by non-private fields
      allow list: if isSignedIn(); 
    }

    match /users/{userId}/scans/{scanId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidScan(incoming());
      allow delete: if false; // Sustainability records are permanent
    }
  }
}
