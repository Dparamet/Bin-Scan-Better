{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile, statistics, and sustainability impact",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "points": { "type": "number" },
        "streak": { "type": "number" },
        "totalScans": { "type": "number" },
        "co2SavedKg": { "type": "number" },
        "currentLeague": { "type": "string" },
        "isPro": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "points", "createdAt"]
    },
    "Scan": {
      "title": "Scan",
      "description": "Record of a waste scan activity and its environmental impact",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "itemName": { "type": "string" },
        "category": { "type": "string" },
        "pointsAwarded": { "type": "number" },
        "impactScore": { "type": "number" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "itemName", "category", "pointsAwarded", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile with aggregated impact stats"
    },
    "users/{userId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Detailed history of individual recycling actions"
    }
  }
}
